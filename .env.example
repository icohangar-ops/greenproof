# GreenProof environment configuration
# Copy to .env and fill in real values. Never commit .env.

# --- AI verification (DashScope / Qwen) ---
# Required to enable the /api/verify endpoint.
DASHSCOPE_API_KEY=
# Optional: override the primary DashScope base URL.
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Optional: override the model (default: qwen-plus).
# DASHSCOPE_MODEL=qwen-plus

# --- API server ---
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=info
